# ── Veritabanı ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://tripclip:tripclip123@localhost:5432/tripclip

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── MongoDB (Qdrant değil, opsiyonel log/metadata için) ──────────────────────
MONGODB_URL=mongodb://localhost:27017/tripclip

# ── JWT ──────────────────────────────────────────────────────────────────────
# Güçlü, rastgele bir secret: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_use_a_strong_random_secret_here

# ── Google Cloud Vision ───────────────────────────────────────────────────────
# JSON anahtar dosyasının yolu (Docker içinde /app/credentials/tripclip-ai.json)
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/tripclip-ai.json

# ── Upload dizini ─────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads/videos

# ── Sentry (opsiyonel — production hata takibi) ───────────────────────────────
# Boş bırakılırsa Sentry devre dışı kalır
SENTRY_DSN=
SENTRY_TRACES_RATE=1.0
